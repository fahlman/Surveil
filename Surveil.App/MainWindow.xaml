<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Surveil.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:views="using:Surveil.App.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Surveil">

    <Grid>
        <muxc:SplitView
            x:Name="ProvisionDrawer"
            PanePlacement="Right"
            DisplayMode="Inline"
            OpenPaneLength="460"
            IsPaneOpen="False">

            <muxc:SplitView.Pane>
                <Grid BorderThickness="1,0,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Padding="16,12,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE9F9;" FontSize="18" />
                            <TextBlock Text="Provision" Style="{StaticResource SubtitleTextBlockStyle}" />
                        </StackPanel>
                        <Button Grid.Column="1" Click="CloseProvision_Click"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                    </Grid>
                    <views:ProvisionPanel Grid.Row="1" />
                </Grid>
            </muxc:SplitView.Pane>

            <muxc:NavigationView
                x:Name="Nav"
                IsBackButtonVisible="Collapsed"
                IsSettingsVisible="False"
                PaneDisplayMode="Left"
                IsPaneToggleButtonVisible="True"
                SelectionChanged="Nav_SelectionChanged"
                Loaded="Nav_Loaded">

                <muxc:NavigationView.MenuItems>
                    <muxc:NavigationViewItem Content="Buildings" Tag="buildings">
                        <muxc:NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE80F;" />
                        </muxc:NavigationViewItem.Icon>
                    </muxc:NavigationViewItem>
                    <muxc:NavigationViewItem Content="Scan" Tag="scan">
                        <muxc:NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE773;" />
                        </muxc:NavigationViewItem.Icon>
                    </muxc:NavigationViewItem>
                    <muxc:NavigationViewItem Content="Discover" Tag="discover">
                        <muxc:NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE71E;" />
                        </muxc:NavigationViewItem.Icon>
                    </muxc:NavigationViewItem>
                </muxc:NavigationView.MenuItems>

                <muxc:NavigationView.FooterMenuItems>
                    <muxc:NavigationViewItem Content="Settings" Tag="settings">
                        <muxc:NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </muxc:NavigationViewItem.Icon>
                    </muxc:NavigationViewItem>
                </muxc:NavigationView.FooterMenuItems>

                <muxc:NavigationView.PaneFooter>
                    <ToggleButton x:Name="ProvisionToggle" Margin="4,4,4,8" HorizontalAlignment="Stretch"
                                  IsChecked="{Binding ElementName=ProvisionDrawer, Path=IsPaneOpen, Mode=TwoWay}"
                                  ToolTipService.ToolTip="Toggle the Provision panel">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE9F9;" FontSize="16" />
                            <TextBlock Text="Provision" />
                        </StackPanel>
                    </ToggleButton>
                </muxc:NavigationView.PaneFooter>

                <Frame x:Name="ContentFrame" />
            </muxc:NavigationView>
        </muxc:SplitView>
    </Grid>
</Window>
