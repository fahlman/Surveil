<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Surveil.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:views="using:Surveil.App.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Surveil">

    <Grid x:Name="RootGrid">
        <muxc:SplitView
            x:Name="ProvisionDrawer"
            PanePlacement="Right"
            DisplayMode="Inline"
            OpenPaneLength="460"
            IsPaneOpen="{Binding IsPaneOpen, Mode=TwoWay}">

            <muxc:SplitView.Pane>
                <Grid BorderThickness="1,0,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Padding="16,10,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="Provision"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            VerticalAlignment="Center" />
                        <Button
                            Grid.Column="1"
                            Command="{Binding ClosePaneCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Close"
                            AutomationProperties.Name="Close Provision panel">
                            <FontIcon Glyph="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                        </Button>
                    </Grid>
                    <views:ProvisionPanel Grid.Row="1" />
                </Grid>
            </muxc:SplitView.Pane>

            <muxc:NavigationView
                x:Name="Nav"
                IsBackButtonVisible="Collapsed"
                IsSettingsVisible="False"
                PaneDisplayMode="LeftCompact"
                OpenPaneLength="200"
                IsPaneToggleButtonVisible="True"
                SelectionChanged="Nav_SelectionChanged"
                Loaded="Nav_Loaded">

                <muxc:NavigationView.MenuItems>
                    <muxc:NavigationViewItem Content="Sites" Tag="sites">
                        <muxc:NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE80F;" />
                        </muxc:NavigationViewItem.Icon>
                    </muxc:NavigationViewItem>
                </muxc:NavigationView.MenuItems>

                <muxc:NavigationView.FooterMenuItems>
                    <muxc:NavigationViewItem Content="Settings" Tag="settings">
                        <muxc:NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </muxc:NavigationViewItem.Icon>
                    </muxc:NavigationViewItem>
                </muxc:NavigationView.FooterMenuItems>

                <Frame x:Name="ContentFrame" />
            </muxc:NavigationView>
        </muxc:SplitView>
    </Grid>
</Window>
