<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Surveil.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:views="using:Surveil.App.Views"
    xmlns:conv="using:Surveil.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Surveil">

    <Grid>
        <Grid.Resources>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        </Grid.Resources>
        <muxc:SplitView
            x:Name="ProvisionDrawer"
            PanePlacement="Right"
            DisplayMode="CompactInline"
            CompactPaneLength="48"
            OpenPaneLength="460"
            IsPaneOpen="True">

            <muxc:SplitView.Pane>
                <Grid BorderThickness="1,0,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Padding="16,10,6,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="Provision"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsPaneOpen, ElementName=ProvisionDrawer, Converter={StaticResource BoolToVis}}" />
                        <Button
                            Grid.Column="1"
                            Click="ToggleProvision_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="9"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            ToolTipService.ToolTip="Show or hide the Provision panel"
                            AutomationProperties.Name="Show or hide the Provision panel">
                            <Grid>
                                <FontIcon
                                    Glyph="&#xE76C;"
                                    FontSize="16"
                                    Visibility="{Binding IsPaneOpen, ElementName=ProvisionDrawer, Converter={StaticResource BoolToVis}}" />
                                <FontIcon
                                    Glyph="&#xE9F9;"
                                    FontSize="18"
                                    Visibility="{Binding IsPaneOpen, ElementName=ProvisionDrawer, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                            </Grid>
                        </Button>
                    </Grid>
                    <views:ProvisionPanel
                        Grid.Row="1"
                        Visibility="{Binding IsPaneOpen, ElementName=ProvisionDrawer, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </muxc:SplitView.Pane>

            <muxc:NavigationView
                x:Name="Nav"
                IsBackButtonVisible="Collapsed"
                IsSettingsVisible="False"
                PaneDisplayMode="LeftCompact"
                OpenPaneLength="200"
                IsPaneToggleButtonVisible="True"
                SelectionChanged="Nav_SelectionChanged"
                Loaded="Nav_Loaded">

                <muxc:NavigationView.MenuItems>
                    <muxc:NavigationViewItem Content="Sites" Tag="sites">
                        <muxc:NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE80F;" />
                        </muxc:NavigationViewItem.Icon>
                    </muxc:NavigationViewItem>
                </muxc:NavigationView.MenuItems>

                <muxc:NavigationView.FooterMenuItems>
                    <muxc:NavigationViewItem Content="Settings" Tag="settings">
                        <muxc:NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </muxc:NavigationViewItem.Icon>
                    </muxc:NavigationViewItem>
                </muxc:NavigationView.FooterMenuItems>

                <Frame x:Name="ContentFrame" />
            </muxc:NavigationView>
        </muxc:SplitView>
    </Grid>
</Window>
