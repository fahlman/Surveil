<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Surveil.App.Views.ConfigurationPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:conv="using:Surveil.App.Converters"
    xmlns:vm="using:Surveil.App.ViewModels">

    <UserControl.Resources>
        <conv:StringToBoolConverter x:Key="StringToBool" />
        <conv:ErrorToSeverityConverter x:Key="ErrorToSeverity" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToBrushConverter x:Key="BoolToBrush" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
        <conv:CountZeroToVisibilityConverter x:Key="CountZeroToVis" />
    </UserControl.Resources>

    <Grid Padding="0,0,0,0" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <muxc:ProgressBar Grid.Row="0" Margin="16,0"
                Value="{Binding ProgressValue}" Maximum="{Binding ProgressMaximum}"
                IsIndeterminate="{Binding ProgressIndeterminate}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />

        <muxc:InfoBar Grid.Row="1" Margin="12,0"
                IsOpen="{Binding StatusMessage, Converter={StaticResource StringToBool}}"
                Severity="{Binding HasError, Converter={StaticResource ErrorToSeverity}}"
                Message="{Binding StatusMessage}" IsClosable="True" />

        <ScrollViewer Grid.Row="2">
                    <StackPanel Spacing="10" Padding="12,4,12,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Targets" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8" />
                            <Border Padding="12,10" CornerRadius="6"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="16" Opacity="0.7" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding SelectedCameraSummary}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding SelectionSummary}" Opacity="0.6" FontSize="12" Margin="26,0,0,0"
                                               Visibility="{Binding SelectionSummary, Converter={StaticResource StringToVis}}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Only settings the whole selection supports appear, and each field is a real
                             value ("Leave unchanged" = skip). Identity is single-camera only (name and
                             hostname are per-device); Video shows only when every camera has encoders. -->
                        <muxc:Expander Header="Identity" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                       Visibility="{Binding SingleCameraSelected, Converter={StaticResource BoolToVis}}">
                            <StackPanel Spacing="8">
                                <TextBox Header="Name" PlaceholderText="e.g. Ground Floor West"
                                         Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Header="Hostname" PlaceholderText="e.g. cam-ground-west"
                                         Text="{Binding Hostname, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </muxc:Expander>

                        <muxc:Expander Header="Time (NTP)" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                       Visibility="{Binding AnyCamerasSelected, Converter={StaticResource BoolToVis}}">
                            <StackPanel Spacing="8">
                                <TextBox Header="NTP server (blank = leave unchanged)" PlaceholderText="e.g. 10.25.0.10 or pool.ntp.org"
                                         Text="{Binding NtpServer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox Header="Time zone" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding AvailableTimeZones}" SelectedItem="{Binding SelectedTimeZone, Mode=TwoWay}"
                                          DisplayMemberPath="Label" />
                            </StackPanel>
                        </muxc:Expander>

                        <muxc:Expander Header="Video" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                       Visibility="{Binding ShowVideoSection, Converter={StaticResource BoolToVis}}">
                            <StackPanel Spacing="8">
                                <ComboBox Header="Codec" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding AvailableCodecs}" SelectedItem="{Binding SelectedCodec, Mode=TwoWay}" />
                                <ComboBox Header="Resolution" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding AvailableResolutions}" SelectedItem="{Binding SelectedResolution, Mode=TwoWay}"
                                          DisplayMemberPath="Label" />
                                <ComboBox Header="Frame rate" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding AvailableFrameRates}" SelectedItem="{Binding SelectedFrameRate, Mode=TwoWay}"
                                          DisplayMemberPath="Label" />
                                <StackPanel Spacing="2" Visibility="{Binding CanSetBitrate, Converter={StaticResource BoolToVis}}">
                                    <muxc:NumberBox Header="Bitrate (kbps — blank leaves it unchanged)"
                                                    Value="{Binding BitrateKbps, Mode=TwoWay}"
                                                    Minimum="{Binding BitrateMinKbps}" Maximum="{Binding BitrateMaxKbps}"
                                                    SpinButtonPlacementMode="Compact" />
                                    <TextBlock Text="{Binding BitrateRangeLabel}" Opacity="0.6"
                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </muxc:Expander>

                        <muxc:InfoBar IsOpen="{Binding VideoHiddenNote, Converter={StaticResource StringToBool}}"
                                      Severity="Informational" IsClosable="False" Message="{Binding VideoHiddenNote}" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Apply" Style="{StaticResource AccentButtonStyle}"
                                    Click="OnApplyClick" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                            <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding IsBusy}" />
                        </StackPanel>

                        <HyperlinkButton Content="Open configuration log" Click="OnOpenLogClick" Padding="0,4" />
                    </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
