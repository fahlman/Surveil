<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Surveil.App.Views.ScanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:conv="using:Surveil.App.Converters"
    xmlns:core="using:Surveil.Core"
    NavigationCacheMode="Required">

    <Page.Resources>
        <conv:UnixTimeToStringConverter x:Key="UnixTime" />
        <conv:StringToBoolConverter x:Key="StringToBool" />
        <conv:ErrorToSeverityConverter x:Key="ErrorToSeverity" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:CountZeroToVisibilityConverter x:Key="CountZeroToVis" />
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Scan" Style="{StaticResource TitleTextBlockStyle}" />

        <TextBox Grid.Row="1" x:Name="TargetsBox" Header="Targets (IPs or CIDR ranges, space/comma separated)"
                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                 PlaceholderText="10.20.0.0/24  192.168.1.0/24"
                 Text="{Binding Targets, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
            <muxc:NumberBox Header="Port" Value="{Binding Port, Mode=TwoWay}" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Compact" Width="120" />
            <muxc:NumberBox Header="Timeout (ms)" Value="{Binding TimeoutMs, Mode=TwoWay}" Minimum="50" Maximum="10000" SpinButtonPlacementMode="Compact" Width="140" />
            <muxc:NumberBox Header="Concurrency" Value="{Binding Concurrency, Mode=TwoWay}" Minimum="1" Maximum="1024" SpinButtonPlacementMode="Compact" Width="140" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button Content="Scan" Style="{StaticResource AccentButtonStyle}"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}" />
            <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding IsScanning}" />
            <muxc:ProgressBar Width="220" VerticalAlignment="Center"
                    Value="{Binding ProgressValue}" Maximum="{Binding ProgressMaximum}"
                    IsIndeterminate="{Binding ProgressIndeterminate}"
                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <muxc:InfoBar Grid.Row="4"
            IsOpen="{Binding StatusMessage, Converter={StaticResource StringToBool}}"
            Severity="{Binding HasError, Converter={StaticResource ErrorToSeverity}}"
            Message="{Binding StatusMessage}" IsClosable="True" />

        <Grid Grid.Row="5" RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Padding="12,4" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="IP" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="Status" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="Building" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="Area" FontWeight="SemiBold" />
                <TextBlock Grid.Column="4" Text="Last seen" FontWeight="SemiBold" />
            </Grid>

            <ListView Grid.Row="1" ItemsSource="{Binding Results}"
                      BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="6">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="core:CameraStatus">
                        <Grid ColumnSpacing="8" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Ip}" FontFamily="Consolas" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Status}" />
                            <TextBlock Grid.Column="2" Text="{x:Bind Building}" />
                            <TextBlock Grid.Column="3" Text="{x:Bind Area}" />
                            <TextBlock Grid.Column="4" Text="{x:Bind LastSeen, Converter={StaticResource UnixTime}}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="1" Text="No results yet — enter targets and press Scan."
                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.55"
                       IsHitTestVisible="False"
                       Visibility="{Binding Results.Count, Converter={StaticResource CountZeroToVis}}" />
        </Grid>
    </Grid>
</Page>
