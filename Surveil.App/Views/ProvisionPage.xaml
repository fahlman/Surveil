<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Surveil.App.Views.ProvisionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:conv="using:Surveil.App.Converters"
    xmlns:vm="using:Surveil.App.ViewModels">

    <Page.Resources>
        <conv:StringToBoolConverter x:Key="StringToBool" />
        <conv:ErrorToSeverityConverter x:Key="ErrorToSeverity" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToBrushConverter x:Key="BoolToBrush" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
    </Page.Resources>

    <Grid Padding="24" ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Settings -->
        <ScrollViewer Grid.Column="0">
            <StackPanel Spacing="12">
                <TextBlock Text="Provision" Style="{StaticResource TitleTextBlockStyle}" />

                <TextBox Header="ONVIF username" Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <PasswordBox x:Name="PasswordInput" Header="ONVIF password" PasswordChanged="OnPasswordChanged" />

                <TextBox Header="Targets (IPs or CIDR ranges)" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                         PlaceholderText="10.20.0.0/24  10.20.1.5"
                         Text="{Binding Targets, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <muxc:Expander Header="Identity" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="8">
                        <CheckBox Content="Set name" IsChecked="{Binding SetName, Mode=TwoWay}" />
                        <CheckBox Content="Set hostname" IsChecked="{Binding SetHostname, Mode=TwoWay}" />
                        <CheckBox Content="Set NTP" IsChecked="{Binding SetNtp, Mode=TwoWay}" />
                        <TextBox Header="NTP POSIX time zone (blank = this computer)"
                                 Text="{Binding NtpPosixTimeZone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </muxc:Expander>

                <muxc:Expander Header="Video" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="8">
                        <CheckBox Content="Maximize video (resolution-first)" IsChecked="{Binding MaximizeVideo, Mode=TwoWay}" />
                        <TextBox Header="Preferred codecs (first supported wins)"
                                 IsEnabled="{Binding MaximizeVideo}"
                                 Text="{Binding PreferredCodecs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </muxc:Expander>

                <CheckBox Content="Skip cameras outside the building map" IsChecked="{Binding SkipUnknownLocation, Mode=TwoWay}" />
                <muxc:NumberBox Header="Max concurrency" Value="{Binding MaxConcurrency, Mode=TwoWay}" Minimum="1" Maximum="64" SpinButtonPlacementMode="Compact" />

                <ToggleSwitch Header="Dry run (read capabilities, write nothing)" IsOn="{Binding DryRun, Mode=TwoWay}" OnContent="On" OffContent="Off" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Preview" Command="{Binding PreviewCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                    <Button Content="Provision" Style="{StaticResource AccentButtonStyle}"
                            Command="{Binding ProvisionCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding IsBusy}" />
                </StackPanel>

                <muxc:ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding ProgressMaximum}"
                        IsIndeterminate="{Binding ProgressIndeterminate}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />

                <muxc:InfoBar
                    IsOpen="{Binding StatusMessage, Converter={StaticResource StringToBool}}"
                    Severity="{Binding HasError, Converter={StaticResource ErrorToSeverity}}"
                    Message="{Binding StatusMessage}" IsClosable="True" />
            </StackPanel>
        </ScrollViewer>

        <!-- Plan + Results -->
        <muxc:Pivot Grid.Column="1">
            <muxc:PivotItem Header="Plan">
                <Grid RowSpacing="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Padding="12,4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="IP" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="Location" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="Name" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="Hostname" FontWeight="SemiBold" />
                    </Grid>
                    <ListView Grid.Row="1" ItemsSource="{Binding Plans}"
                              BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="6">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProvisionPlanRow">
                                <Grid ColumnSpacing="8" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Address}" FontFamily="Consolas" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Location}" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind Name}" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind Hostname}" FontFamily="Consolas" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </muxc:PivotItem>

            <muxc:PivotItem Header="Results">
                <ListView ItemsSource="{Binding Results}"
                          BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="6">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProvisionResultRow">
                            <Grid ColumnSpacing="12" Padding="4,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" FontFamily="Segoe MDL2 Assets" Glyph="{x:Bind Glyph}"
                                          Foreground="{x:Bind Success, Converter={StaticResource BoolToBrush}}"
                                          VerticalAlignment="Top" Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="{x:Bind Address}" FontFamily="Consolas" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind Location}" Opacity="0.8" />
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Steps}" Opacity="0.9" TextWrapping="Wrap"
                                               Visibility="{x:Bind Steps, Converter={StaticResource StringToVis}}" />
                                    <TextBlock Text="{x:Bind VideoSummary}" FontFamily="Consolas" FontSize="12" Opacity="0.9" TextWrapping="Wrap"
                                               Visibility="{x:Bind HasVideo, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="{x:Bind Error}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap"
                                               Visibility="{x:Bind HasError, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </muxc:PivotItem>
        </muxc:Pivot>
    </Grid>
</Page>
