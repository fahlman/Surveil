<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Surveil.App.Views.CameraRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Surveil.App.Converters">

    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
        <conv:BoolToVisibilityConverter x:Key="RowVis" />
        <conv:LoginStateToBrushConverter x:Key="StateBrush" />
    </UserControl.Resources>

    <Grid ColumnSpacing="8" Padding="0,2"
          Visibility="{Binding IsVisible, Converter={StaticResource RowVis}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <CheckBox Grid.Column="0" MinWidth="0" VerticalAlignment="Center"
                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                  ToolTipService.ToolTip="Select this camera to provision" />
        <FontIcon Grid.Column="1" Glyph="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{Binding Ip}" FontFamily="Consolas" VerticalAlignment="Center" />
        <FontIcon Grid.Column="3" Glyph="{Binding StateGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center"
                  Foreground="{Binding LoginState, Converter={StaticResource StateBrush}}"
                  Visibility="{Binding HasStateGlyph, Converter={StaticResource RowVis}}"
                  ToolTipService.ToolTip="{Binding ErrorText}" />
        <TextBlock Grid.Column="4" Text="{Binding StatusLine}" Opacity="0.85" VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding StatusLine}" />

        <!-- Full feature detail on demand -->
        <Button Grid.Column="5" Background="Transparent" BorderThickness="0" Padding="6,2" VerticalAlignment="Center"
                Visibility="{Binding CanShowDetails, Converter={StaticResource RowVis}}"
                ToolTipService.ToolTip="Camera details">
            <FontIcon Glyph="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13" Opacity="0.7" />
            <Button.Flyout>
                <Flyout>
                    <StackPanel Spacing="6" MaxWidth="400">
                        <TextBlock Text="{Binding Identity}" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ServicesText}" TextWrapping="Wrap" Opacity="0.85"
                                   Visibility="{Binding ServicesText, Converter={StaticResource StringToVis}}" />
                        <TextBlock Text="{Binding VideoText}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Opacity="0.85"
                                   Visibility="{Binding VideoText, Converter={StaticResource StringToVis}}" />
                        <TextBlock Text="{Binding MoreText}" TextWrapping="Wrap" Opacity="0.6" FontSize="12"
                                   Visibility="{Binding MoreText, Converter={StaticResource StringToVis}}" />
                    </StackPanel>
                </Flyout>
            </Button.Flyout>
        </Button>
    </Grid>
</UserControl>
