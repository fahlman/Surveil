<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Surveil.App.Views.InventoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:conv="using:Surveil.App.Converters"
    xmlns:core="using:Surveil.Core"
    NavigationCacheMode="Required">

    <Page.Resources>
        <conv:UnixTimeToStringConverter x:Key="UnixTime" />
        <conv:StringToBoolConverter x:Key="StringToBool" />
        <conv:ErrorToSeverityConverter x:Key="ErrorToSeverity" />
        <conv:CountZeroToVisibilityConverter x:Key="CountZeroToVis" />
        <conv:CountPositiveToBoolConverter x:Key="CountPositiveToBool" />
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Inventory" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="{Binding Summary}" Opacity="0.7" Style="{StaticResource CaptionTextBlockStyle}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Refresh" Command="{Binding LoadCommand}" />
            <Button Content="Export CSV…" Click="OnExportClick"
                    IsEnabled="{Binding Cameras.Count, Converter={StaticResource CountPositiveToBool}}" />
        </StackPanel>

        <muxc:InfoBar Grid.Row="2"
            IsOpen="{Binding StatusMessage, Converter={StaticResource StringToBool}}"
            Severity="{Binding HasError, Converter={StaticResource ErrorToSeverity}}"
            Message="{Binding StatusMessage}" IsClosable="True" />

        <Grid Grid.Row="3" RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="12,4" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="IP" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="Building" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="Area" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="First seen" FontWeight="SemiBold" />
                <TextBlock Grid.Column="4" Text="Last seen" FontWeight="SemiBold" />
            </Grid>

            <ListView Grid.Row="1" ItemsSource="{Binding Cameras}"
                      BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="6">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="core:CameraRecord">
                        <Grid ColumnSpacing="8" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Ip}" FontFamily="Consolas" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Building}" />
                            <TextBlock Grid.Column="2" Text="{x:Bind Area}" />
                            <TextBlock Grid.Column="3" Text="{x:Bind FirstSeen, Converter={StaticResource UnixTime}}" />
                            <TextBlock Grid.Column="4" Text="{x:Bind LastSeen, Converter={StaticResource UnixTime}}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="1" Text="No cameras in inventory yet — run a Scan to populate it."
                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.55" IsHitTestVisible="False"
                       Visibility="{Binding Cameras.Count, Converter={StaticResource CountZeroToVis}}" />
        </Grid>
    </Grid>
</Page>
