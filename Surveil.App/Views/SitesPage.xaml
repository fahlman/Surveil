<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Surveil.App.Views.SitesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:conv="using:Surveil.App.Converters"
    xmlns:vm="using:Surveil.App.ViewModels"
    xmlns:views="using:Surveil.App.Views"
    xmlns:controls="using:Surveil.App.Controls"
    xmlns:core="using:Surveil.Core"
    NavigationCacheMode="Required">

    <Page.Resources>
        <conv:StringToBoolConverter x:Key="StringToBool" />
        <conv:ErrorToSeverityConverter x:Key="ErrorToSeverity" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:CountPositiveToVisibilityConverter x:Key="CountPositiveToVis" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Sites" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="{Binding DataDirectory}" Opacity="0.7" Style="{StaticResource CaptionTextBlockStyle}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Command="{Binding SaveCommand}" />
            <Button Content="Import…" Click="OnImportClick" />
            <Button Content="Export…" Click="OnExportClick" />
            <Border Width="1" Height="24" Margin="4,0" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Button Content="Discover" Click="OnDiscoverClick"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    ToolTipService.ToolTip="Find ONVIF cameras on the local network, then optionally port-scan the checked ranges" />
            <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding IsBusy}" />
            <muxc:ProgressRing Width="20" Height="20" VerticalAlignment="Center"
                    IsActive="{Binding IsBusy}"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Spacing="8">
            <!-- Determinate while scanning (fills as addresses are probed); animated while discovering. -->
            <muxc:ProgressBar
                Value="{Binding ScanProgressValue}" Maximum="{Binding ScanProgressMaximum}"
                IsIndeterminate="{Binding IsDiscovering}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            <muxc:InfoBar
                IsOpen="{Binding StatusMessage, Converter={StaticResource StringToBool}}"
                Severity="{Binding HasError, Converter={StaticResource ErrorToSeverity}}"
                Message="{Binding StatusMessage}" IsClosable="True" />
        </StackPanel>

        <!-- Faceted filters — populated from what identification discovered; wraps to fit the width -->
        <StackPanel Grid.Row="3" Spacing="6"
                    Visibility="{Binding Facets.Count, Converter={StaticResource CountPositiveToVis}}">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Opacity="0.7" VerticalAlignment="Center" />
                <TextBlock Text="Filters" FontWeight="SemiBold" Opacity="0.85" VerticalAlignment="Center" />
                <TextBlock Text="{Binding FilterSummary}" Opacity="0.6" VerticalAlignment="Center" />
                <Button Content="Clear" Command="{Binding ClearFiltersCommand}" Padding="10,2"
                        Visibility="{Binding FilterActive, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
            <ItemsControl ItemsSource="{Binding Facets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:WrapPanel HorizontalSpacing="6" VerticalSpacing="6" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:FacetGroup">
                        <DropDownButton Content="{x:Bind HeaderLabel, Mode=OneWay}">
                            <DropDownButton.Flyout>
                                <Flyout>
                                    <ScrollViewer MaxHeight="320" MinWidth="180">
                                        <ItemsControl ItemsSource="{x:Bind Options}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:FacetOption">
                                                    <CheckBox MinWidth="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                              Content="{x:Bind Label, Mode=OneWay}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Flyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <ScrollViewer Grid.Row="4">
            <StackPanel>
            <ItemsControl ItemsSource="{Binding Sites}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SiteItem">
                        <StackPanel Margin="0,0,0,6"
                                    Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}">

                            <!-- Site (parent) row -->
                            <Grid ColumnSpacing="4" Padding="6,4" CornerRadius="6"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                  BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" MinWidth="0" VerticalAlignment="Center"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          ToolTipService.ToolTip="Select all CIDRs in this site" />

                                <Button Grid.Column="1" Command="{x:Bind ToggleExpandCommand}"
                                        Background="Transparent" BorderThickness="0" Padding="6,4"
                                        ToolTipService.ToolTip="Expand / collapse">
                                    <Grid>
                                        <FontIcon Glyph="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                  Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                        <FontIcon Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                  Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                    </Grid>
                                </Button>

                                <TextBox Grid.Column="2" Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Grid.Column="2" Text="{x:Bind Name, Mode=OneWay}" VerticalAlignment="Center"
                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                           ToolTipService.ToolTip="{x:Bind Name, Mode=OneWay}"
                                           Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                                <Button Grid.Column="3" Command="{x:Bind ToggleEditCommand}">
                                    <Grid>
                                        <FontIcon Glyph="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                  Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}" ToolTipService.ToolTip="Done" />
                                        <FontIcon Glyph="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                  Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" ToolTipService.ToolTip="Edit name" />
                                    </Grid>
                                </Button>
                                <Button Grid.Column="4" Command="{x:Bind RemoveCommand}" ToolTipService.ToolTip="Delete site">
                                    <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                                </Button>
                                <Button Grid.Column="5" Command="{x:Bind AddSiteCommand}" ToolTipService.ToolTip="Add site">
                                    <FontIcon Glyph="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                                </Button>
                            </Grid>

                            <!-- CIDR children -->
                            <StackPanel Margin="24,4,0,0"
                                        Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <ItemsControl ItemsSource="{x:Bind Children}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:NetworkRangeItem">
                                            <StackPanel Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                                <Grid ColumnSpacing="6" Padding="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" MinWidth="120" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox Grid.Column="0" MinWidth="0" VerticalAlignment="Center"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              ToolTipService.ToolTip="Select this CIDR for scanning" />

                                                    <TextBox Grid.Column="1" PlaceholderText="Area / name"
                                                             Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                                    <TextBox Grid.Column="2" PlaceholderText="CIDR e.g. 10.20.0.0/24"
                                                             Text="{x:Bind Cidr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                                                    <TextBlock Grid.Column="1" Text="{x:Bind Name, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                               ToolTipService.ToolTip="{x:Bind Name, Mode=OneWay}"
                                                               Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                                    <TextBlock Grid.Column="2" Text="{x:Bind Cidr, Mode=OneWay}" VerticalAlignment="Center" FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                                               ToolTipService.ToolTip="{x:Bind Cidr, Mode=OneWay}"
                                                               Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                                                    <Button Grid.Column="3" Command="{x:Bind ToggleEditCommand}">
                                                        <Grid>
                                                            <FontIcon Glyph="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                      Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}" ToolTipService.ToolTip="Done" />
                                                            <FontIcon Glyph="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                      Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" ToolTipService.ToolTip="Edit" />
                                                        </Grid>
                                                    </Button>
                                                    <Button Grid.Column="4" Command="{x:Bind RemoveCommand}" ToolTipService.ToolTip="Delete range">
                                                        <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                                                    </Button>
                                                    <Button Grid.Column="5" Command="{x:Bind AddSiblingCommand}" ToolTipService.ToolTip="Add range below">
                                                        <FontIcon Glyph="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                                                    </Button>
                                                </Grid>

                                                <!-- Cameras found in this CIDR (checkbox = configuration target) -->
                                                <ItemsControl ItemsSource="{x:Bind Cameras}" Margin="30,0,0,4">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:CameraItem">
                                                            <views:CameraRow />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Unmapped group: cameras found outside every mapped CIDR (from Discover) -->
            <StackPanel Margin="0,6,0,0"
                        Visibility="{Binding UnmappedGroupVisible, Converter={StaticResource BoolToVis}}">
                <Grid ColumnSpacing="4" Padding="6,4" CornerRadius="6"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding ToggleUnmappedCommand}"
                            Background="Transparent" BorderThickness="0" Padding="6,4"
                            ToolTipService.ToolTip="Expand / collapse">
                        <Grid>
                            <FontIcon Glyph="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                      Visibility="{Binding UnmappedExpanded, Converter={StaticResource BoolToVis}}" />
                            <FontIcon Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                      Visibility="{Binding UnmappedExpanded, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                        </Grid>
                    </Button>
                    <TextBlock Grid.Column="1" Text="Unmapped" VerticalAlignment="Center" FontWeight="SemiBold" Opacity="0.85" />
                </Grid>
                <ItemsControl ItemsSource="{Binding UnmappedCameras}" Margin="30,4,0,0"
                              Visibility="{Binding UnmappedExpanded, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CameraItem">
                            <views:CameraRow />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
